{
  "manifest_version": 3,
  "name": "History Search",
  "version": "1.0.0",
  "description": "Semantic search over your browser history — fully local, no data leaves your device.",

  "permissions": [
    "tabs",
    "activeTab",
    "nativeMessaging",
    "storage"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "History Search",
    "default_icon": {
      "16":  "assets/icon16.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },

  "icons": {
    "16":  "assets/icon16.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}